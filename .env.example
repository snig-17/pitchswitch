# PitchSwitch - LLM Provider Configuration
# Copy this file to .env and fill in the provider you're using.

# Which Granite provider to use: "ollama", "watsonx", or "replicate"
LLM_PROVIDER=ollama

# --- Ollama (local, free) — runs IBM Granite locally ---
# Install: brew install ollama && ollama pull granite3.3:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=granite3.3:8b
# Smaller/faster Granite for low-RAM machines:
# OLLAMA_MODEL=granite3.3:2b

# --- IBM watsonx.ai (cloud) — Granite served on watsonx ---
# Note: Granite text models are in us-south (Dallas), not eu-gb (London).
# WATSONX_API_KEY=your-api-key
# WATSONX_PROJECT_ID=your-project-id
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
# WATSONX_MODEL=ibm/granite-3-8b-instruct

# --- Replicate (cloud) ---
# REPLICATE_API_TOKEN=your-token
# REPLICATE_MODEL=ibm-granite/granite-3.1-8b-instruct

# Replay settings
REPLAY_SPEED=60
DEMO_MODE=false
